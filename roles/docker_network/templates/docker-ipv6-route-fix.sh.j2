#!/usr/bin/env bash
# Replace the broad bridge subnet route with a narrow pool route, and
# masquerade ULA egress so private-only containers can reach the internet
# via the host's own public IPv6.

BRIDGE="{{ docker_network_bridge_iface }}"
PUBLIC_SUBNET="{{ docker_network_bridge_public_subnet | default('') }}"
POOL="{{ docker_network_ipv6_pool | default('') }}"
PRIVATE_SUBNET="{{ docker_network_ipv6_private_subnet | default('') }}"

# Wait for bridge to exist (Docker may still be starting)
for i in $(seq 1 30); do
    ip link show "$BRIDGE" &>/dev/null && break
    sleep 1
done

# Replace Docker's broad public-subnet route on the bridge with a narrow pool
# route, so reply packets find the bridge correctly when the bridge subnet
# overlaps with the host's interface subnet.
if [ -n "$PUBLIC_SUBNET" ] && [ -n "$POOL" ]; then
    ip -6 route del "$PUBLIC_SUBNET" dev "$BRIDGE" 2>/dev/null
    ip -6 route replace "$POOL" dev "$BRIDGE"
fi

# Allow IPv6 forwarding through Docker's DOCKER-USER chain
ip6tables -C DOCKER-USER -j ACCEPT 2>/dev/null || ip6tables -I DOCKER-USER -j ACCEPT

# Masquerade ULA egress so containers without a static public IPv6 can still
# reach the internet, leaving with the host's public IPv6 as source.
if [ -n "$PRIVATE_SUBNET" ]; then
    ip6tables -t nat -C POSTROUTING -s "$PRIVATE_SUBNET" ! -o "$BRIDGE" -j MASQUERADE 2>/dev/null \
        || ip6tables -t nat -A POSTROUTING -s "$PRIVATE_SUBNET" ! -o "$BRIDGE" -j MASQUERADE
fi
